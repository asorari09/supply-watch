# Required runtime configuration
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# TICK_SECRET=  # generate: openssl rand -hex 32
# SUPABASE_DB_PASSWORD=

# Optional provider configuration
# OPENAI_API_KEY=
# ENABLE_LLM_NEWS= # Optional; defaults to false
# MAX_NEWS_LLM_PER_TICK= # Optional; defaults to 3 filtered items per tick
# ENABLE_LLM_NARRATION= # Optional; defaults to false
# MAX_NARRATION_PER_TICK= # Optional; defaults to 5 per tick
# LANGFUSE_PUBLIC_KEY= # Optional tracing
# LANGFUSE_SECRET_KEY= # Optional tracing
# LANGFUSE_BASE_URL= # Optional tracing
# ANTHROPIC_API_KEY=
# LLM_MODEL_NEWS=
# LLM_MODEL_NARRATION=
# LLM_MODEL_COMMS=
# OPEN_METEO_BASE_URL=
# WEATHER_TIMEOUT_MS= # Optional; defaults to 8000 milliseconds
# WEATHER_RETRIES= # Optional; defaults to 2 retries
# NEWS_RSS_FEEDS=
# NEWS_TIMEOUT_MS= # Optional; defaults to 8000 milliseconds
